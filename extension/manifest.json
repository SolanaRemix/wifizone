{
  "manifest_version": 3,
  "name": "WIFIZONE Manager",
  "version": "1.0.0",
  "description": "Quick access to your WIFIZONE hotspot dashboard — see live stats, active users, and earnings at a glance.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WIFIZONE Manager",
    "default_icon": {
      "16":  "icons/icon16.svg",
      "32":  "icons/icon32.svg",
      "48":  "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16":  "icons/icon16.svg",
    "32":  "icons/icon32.svg",
    "48":  "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
